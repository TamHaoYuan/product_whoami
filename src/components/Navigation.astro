---
import { getSiteConfig, getSocialConfig, isFeatureEnabled } from '@utils/config';
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

// Get all blog posts
const blogPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Extract and count categories
const categories = blogPosts.reduce((acc, post) => {
  if (post.data.categories) {
    post.data.categories.forEach(category => {
      acc[category] = (acc[category] || 0) + 1;
    });
  }
  return acc;
}, {} as Record<string, number>);

// Convert to array and sort alphabetically
const sortedCategories = Object.entries(categories)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([name, count]) => ({ name, count }));

const { class: className } = Astro.props;

// Get site configuration
const siteConfig = getSiteConfig();
const socialConfig = getSocialConfig();
const showAttribution = isFeatureEnabled('attribution');

// Get current path for active state detection
const currentPath = Astro.url.pathname;

// Helper function to determine if a link is active
function isActiveLink(linkPath: string): boolean {
  if (linkPath === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(linkPath);
}

// Helper function to determine if a category is active
function isActiveCategory(categoryName: string): boolean {
  const categoryPath = `/categories/${categoryName.toLowerCase().replace(/\s+/g, '-')}`;
  return currentPath.startsWith(categoryPath);
}
---

<nav class:list={["bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 h-full p-4 flex flex-col", className]}>
  <div class="py-4 border-b border-slate-200 dark:border-slate-800 mb-4">
    <a href="/" class="flex items-center gap-2 text-2xl font-bold text-xuxiang-600 dark:text-xuxiang-400">
      <Icon name="home" class="w-8 h-8" />
      <span>{siteConfig.brandTitle}贴吧</span>
    </a>
  </div>

  <div class="mt-4 space-y-6 flex-1">
    <div>
      <h3 class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400 font-semibold mb-3">吧内导航</h3>
      <ul class="space-y-2">
        <li>
          <a href="/" class:list={[
            "flex items-center gap-2 p-2 rounded-lg transition-colors",
            isActiveLink('/') 
              ? "bg-xuxiang-100 dark:bg-xuxiang-900/30 text-xuxiang-700 dark:text-xuxiang-300 font-medium" 
              : "hover:bg-slate-100 dark:hover:bg-slate-800"
          ]}>
            <Icon name="home" class:list={[
              "w-5 h-5",
              isActiveLink('/') ? "text-xuxiang-600 dark:text-xuxiang-400" : ""
            ]} />
            <span>吧首页</span>
          </a>
        </li>
        <li>
          <a href="/blog" class:list={[
            "flex items-center gap-2 p-2 rounded-lg transition-colors",
            isActiveLink('/blog') 
              ? "bg-xuxiang-100 dark:bg-xuxiang-900/30 text-xuxiang-700 dark:text-xuxiang-300 font-medium" 
              : "hover:bg-slate-100 dark:hover:bg-slate-800"
          ]}>
            <Icon name="file-text" class:list={[
              "w-5 h-5",
              isActiveLink('/blog') ? "text-xuxiang-600 dark:text-xuxiang-400" : ""
            ]} />
            <span>最近的议论</span>
          </a>
        </li>
        <li>
          <a href="/create" class:list={[
            "flex items-center gap-2 p-2 rounded-lg transition-colors",
            isActiveLink('/create') 
              ? "bg-xuxiang-100 dark:bg-xuxiang-900/30 text-xuxiang-700 dark:text-xuxiang-300 font-medium" 
              : "hover:bg-slate-100 dark:hover:bg-slate-800"
          ]}>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span>分享故事</span>
          </a>
        </li>
        <li>
          <a href="/categories" class:list={[
            "flex items-center gap-2 p-2 rounded-lg transition-colors",
            isActiveLink('/categories') 
              ? "bg-xuxiang-100 dark:bg-xuxiang-900/30 text-xuxiang-700 dark:text-xuxiang-300 font-medium" 
              : "hover:bg-slate-100 dark:hover:bg-slate-800"
          ]}>
            <Icon name="tag" class:list={[
              "w-5 h-5",
              isActiveLink('/categories') ? "text-xuxiang-600 dark:text-xuxiang-400" : ""
            ]} />
            <span>话题分类</span>
          </a>
        </li>
        <li>
          <a href="/about" class:list={[
            "flex items-center gap-2 p-2 rounded-lg transition-colors",
            isActiveLink('/about') 
              ? "bg-xuxiang-100 dark:bg-xuxiang-900/30 text-xuxiang-700 dark:text-xuxiang-300 font-medium" 
              : "hover:bg-slate-100 dark:hover:bg-slate-800"
          ]}>
            <Icon name="user" class:list={[
              "w-5 h-5",
              isActiveLink('/about') ? "text-xuxiang-600 dark:text-xuxiang-400" : ""
            ]} />
            <span>关于虚像</span>
          </a>
        </li>
      </ul>
    </div>

    {sortedCategories.length > 0 && (
      <div>
        <h3 class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400 font-semibold mb-3">话题分类</h3>
        <ul class="space-y-1">
          {sortedCategories.map(({ name, count }) => (
            <li>
              <a 
                href={`/categories/${name.toLowerCase().replace(/\s+/g, '-')}`} 
                class:list={[
                  "block p-2 rounded-lg transition-colors flex justify-between items-center",
                  isActiveCategory(name)
                    ? "bg-xuxiang-100 dark:bg-xuxiang-900/30 text-xuxiang-700 dark:text-xuxiang-300 font-medium"
                    : "hover:bg-slate-100 dark:hover:bg-slate-800"
                ]}
              >
                <span>{name}</span>
                <span class:list={[
                  "text-xs rounded-full px-2 py-0.5",
                  isActiveCategory(name)
                    ? "bg-xuxiang-200 dark:bg-xuxiang-800 text-xuxiang-800 dark:text-xuxiang-200"
                    : "bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300"
                ]}>{count}帖</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>

  <div class="mt-auto pt-4 border-t border-slate-200 dark:border-slate-800">
    <div class:list={["flex items-center justify-between", showAttribution ? "mb-2" : ""]}>
      <div class="flex space-x-2">
        <a href={socialConfig.github} class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="GitHub">
          <Icon name="github" class="w-5 h-5" />
        </a>
        <a href={socialConfig.linkedin} class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="LinkedIn">
          <Icon name="linkedin" class="w-5 h-5" />
        </a>
        <a href="/api/rss.xml" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="RSS">
          <Icon name="rss" class="w-5 h-5" />
        </a>
      </div>
      <ThemeToggle />
    </div>
    {showAttribution && (
      <div class="text-xs text-center text-slate-400 dark:text-slate-500">
        <a href="https://github.com/copyboy/product_whoami" target="_blank" rel="noopener noreferrer" class="hover:text-xuxiang-600 dark:hover:text-xuxiang-400 transition-colors">
          虚像茶馆 © 2026
        </a>
      </div>
    )}
  </div>
</nav>