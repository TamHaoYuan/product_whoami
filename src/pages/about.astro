---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getSiteConfig } from '@utils/config';

const siteConfig = getSiteConfig();
---

<BaseLayout title={`关于 | ${siteConfig.title}`}>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 py-12">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8">
        <h1 class="text-3xl font-bold text-slate-800 dark:text-slate-200 mb-8 text-center">
          关于虚像茶馆
        </h1>
        
        <div class="prose dark:prose-invert max-w-none space-y-6">
          <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            欢迎来到虚像茶馆。
          </p>
          
          <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            这里是一个特别的场所——故事中的人物们聚在一起，议论故事的地方。
          </p>
          
          <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            不同于读者从外部观察故事，这里是角色们从内部讨论他们所处的世界。
            无论是《恶意》中的凶手讨论自己的犯罪动机，
            还是《萤火虫》中的幸存者回忆那段最后的时光，
            或者是任何一个故事中的角色，对剧情发表自己的看法……
          </p>
          
          <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            在这里，你可以是任何故事中的任何人物，
            以角色的身份与其他故事的角色一起，
            从非上帝视角讨论那些令人难忘的故事、角色和剧情。
          </p>
          
          <div class="border-t border-slate-200 dark:border-slate-700 pt-8 mt-8">
            <h2 class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-4">
              使用说明
            </h2>
            <ul class="space-y-3 text-slate-600 dark:text-slate-300">
              <li class="flex items-start gap-3">
                <span class="text-xuxiang-600 dark:text-xuxiang-400">✓</span>
                <span>无需注册，选择你的身份即可开始议论</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-xuxiang-600 dark:text-xuxiang-400">✓</span>
                <span>可以自定义用户名和头像</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-xuxiang-600 dark:text-xuxiang-400">✓</span>
                <span>管理员密码：admin2026</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-xuxiang-600 dark:text-xuxiang-400">✓</span>
                <span>站长密码：owner2026</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-xuxiang-600 dark:text-xuxiang-400">✓</span>
                <span>尽情分享你对故事的见解吧</span>
              </li>
            </ul>
          </div>
          
          <div class="text-center mt-12 pt-8 border-t border-slate-200 dark:border-slate-700">
            <a
              href="/create"
              class="inline-block px-6 py-3 bg-xuxiang-600 hover:bg-xuxiang-700 text-white rounded-lg transition-colors"
            >
              开始议论
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>