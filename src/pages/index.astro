---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import Sidebar from '@components/Sidebar.astro';
import MobileNav from '@components/MobileNav.astro';
import PostList from '@components/islands/PostList';
import { getSiteConfig } from '@utils/config';

const siteConfig = getSiteConfig();
---

<BaseLayout title={`首页 | ${siteConfig.title}`}>
  <div class="flex flex-col lg:flex-row min-h-screen bg-slate-50 dark:bg-slate-900">
    <MobileNav />
    <Navigation class="hidden lg:flex lg:flex-col lg:w-60 lg:fixed lg:inset-y-0 shrink-0 bg-white dark:bg-slate-800 shadow-md" />
    
    <main class="flex-1 w-full px-4 pt-16 lg:pt-0 lg:ml-60 xl:mr-64">
      <div class="max-w-4xl mx-auto py-6">
        <header class="pb-6 border-b border-slate-200 dark:border-slate-800 mb-6">
          <div class="flex justify-between items-center">
            <div>
              <h1 class="text-3xl font-bold mb-2 text-xuxiang-600 dark:text-xuxiang-400">{siteConfig.homeTitle}</h1>
              <p class="text-lg text-slate-600 dark:text-slate-300">
                {siteConfig.homeSubtitle}
              </p>
            </div>
            <a
              href="/create"
              class="hidden sm:inline-flex items-center px-4 py-2 bg-xuxiang-600 hover:bg-xuxiang-700 text-white rounded-lg transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              分享故事
            </a>
          </div>
        </header>

        <section>
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold text-slate-800 dark:text-slate-200">最近的议论</h2>
            <a href="/create" class="sm:hidden text-xuxiang-600 dark:text-xuxiang-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </a>
          </div>
          <PostList client:load />
        </section>
      </div>
    </main>

    <Sidebar class="hidden xl:block xl:w-64 shrink-0 fixed right-0 top-0 bottom-0 bg-white dark:bg-slate-800 shadow-md" />
  </div>
</BaseLayout>